DB_HOST=seeco-db.postgres.database.azure.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_database_password
DB_SSLMODE=require

# Comma-separated frontend origins allowed to call the backend.
# Use your deployed frontend URL in production.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_BASE_URL=http://127.0.0.1:5173

# Upload limits for /api/upload and /api/analyse/company report files.
MAX_UPLOAD_MB=10
MAX_REPORT_UPLOAD_MB=10

# Layer A IUCN cache settings.
# Disk cache avoids re-fetching all Australian IUCN records on every restart.
WARM_IUCN_CACHE_ON_STARTUP=true
IUCN_CACHE_MAX_AGE_HOURS=168
IUCN_CACHE_FILE=

# Email delivery for report and verification emails.
# EMAIL_DELIVERY_MODE=auto uses SMTP when fully configured, otherwise writes to backend/outbox/.
# Use EMAIL_DELIVERY_MODE=smtp in production so send failures are visible.
EMAIL_DELIVERY_MODE=auto

# Resend SMTP. Create an API key in Resend and verify the REPORT_FROM_EMAIL domain.
# Resend SMTP credentials are:
# host=smtp.resend.com, username=resend, password=RESEND_API_KEY.
EMAIL_PROVIDER=resend
RESEND_API_KEY=your_resend_api_key
REPORT_FROM_EMAIL=noreply@your-verified-domain.com
REPORT_FROM_NAME=Seeco
REPORT_REPLY_TO=

# Generic SMTP override. Leave blank when EMAIL_PROVIDER=resend is used.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=30
SMTP_REQUIRE_AUTH=true

# ABN lookup API
ABR_GUID=your_abr_guid

# Australian Trade Mark Search API
IP_AUSTRALIA_CLIENT_ID=your_ip_australia_client_id
IP_AUSTRALIA_CLIENT_SECRET=your_ip_australia_client_secret
IP_AUSTRALIA_TOKEN_URL=https://test.api.ipaustralia.gov.au/public/external-token-api/v1/access_token
IP_AUSTRALIA_TRADEMARK_URL=https://test.api.ipaustralia.gov.au/public/australian-trade-mark-search-api/v1/

# News/search APIs for /api/analyse/company
SERPAPI_KEY=your_serpapi_key
NEWSAPI_KEY=your_newsapi_key
WEBZ_API_KEY=your_webz_api_key
GUARDIAN_API_KEY=your_guardian_api_key
NYT_API_KEY=your_nyt_api_key
FREENEWS_API_KEY=your_freenews_api_key
NEWSDATA_IO_API_KEY=your_newsdata_io_api_key

# LLM provider for evidence extraction
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
NVIDIA_API_KEY=your_nvidia_api_key
NVIDIA_NIM_MODEL=nvidia/nemotron-3-super-120b-a12b
