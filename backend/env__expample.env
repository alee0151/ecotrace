DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecotrace
DB_USER=postgres
DB_PASSWORD=your_database_password
DB_SSLMODE=require

# ABN lookup API
ABR_GUID=your_abr_guid

# Australian Trade Mark Search API
IP_AUSTRALIA_CLIENT_ID=your_ip_australia_client_id
IP_AUSTRALIA_CLIENT_SECRET=your_ip_australia_client_secret
IP_AUSTRALIA_TOKEN_URL=https://test.api.ipaustralia.gov.au/public/external-token-api/v1/access_token
IP_AUSTRALIA_TRADEMARK_URL=https://test.api.ipaustralia.gov.au/public/australian-trade-mark-search-api/v1/

# News/search APIs for /api/analyse/company
SERPAPI_KEY=your_serpapi_key
NEWSAPI_KEY=your_newsapi_key
WEBZ_API_KEY=your_webz_api_key
GUARDIAN_API_KEY=your_guardian_api_key
NYT_API_KEY=your_nyt_api_key
FREENEWS_API_KEY=your_freenews_api_key
NEWSDATA_IO_API_KEY=your_newsdata_io_api_key

# LLM provider for evidence extraction
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
NVIDIA_API_KEY=your_nvidia_api_key
NVIDIA_NIM_MODEL=nvidia/nemotron-3-super-120b-a12b
