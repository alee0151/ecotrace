# Copy these into Azure App Service > Settings > Environment variables.
# Do not commit real secret values.

SCM_DO_BUILD_DURING_DEPLOYMENT=true
ENABLE_ORYX_BUILD=true

DB_HOST=seeco-db.postgres.database.azure.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=<secret>
DB_SSLMODE=require

CORS_ALLOW_ORIGINS=https://seeco.me,https://www.seeco.me,https://<your-frontend-app>.azurewebsites.net
FRONTEND_BASE_URL=https://seeco.me

MAX_REPORT_UPLOAD_MB=25
MAX_UPLOAD_MB=25
UPLOAD_DIR=/home/site/wwwroot/backend/uploads

WARM_IUCN_CACHE_ON_STARTUP=true
IUCN_CACHE_MAX_AGE_HOURS=168

EMAIL_DELIVERY_MODE=smtp
EMAIL_PROVIDER=resend
RESEND_API_KEY=<secret>
REPORT_FROM_EMAIL=noreply@<your-verified-domain>
REPORT_FROM_NAME=Seeco
REPORT_REPLY_TO=

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=30
SMTP_REQUIRE_AUTH=true

ABR_GUID=<secret>
IP_AUSTRALIA_CLIENT_ID=<secret>
IP_AUSTRALIA_CLIENT_SECRET=<secret>
SERPAPI_KEY=<secret>
NEWSAPI_KEY=<secret>
WEBZ_API_KEY=<secret>
GUARDIAN_API_KEY=<secret>
NYT_API_KEY=<secret>
FREENEWS_API_KEY=<secret>
NEWSDATA_IO_API_KEY=<secret>
MEDIASTACK_API_KEY=<secret>

LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=<secret>
OPENROUTER_MODEL=
